DOXYFILE_ENCODING      = UTF-8
PROJECT_NAME           = "OpenPit C++ SDK"
PROJECT_BRIEF          = "C++17 SDK for the OpenPit pre-trade risk engine"
OUTPUT_DIRECTORY       = docs/cpp-api
OUTPUT_LANGUAGE        = English

INPUT                  = bindings/cpp/DoxygenMainPage.md \
                         bindings/cpp/include/openpit
USE_MDFILE_AS_MAINPAGE = bindings/cpp/DoxygenMainPage.md
FILE_PATTERNS          = *.hpp *.md
RECURSIVE              = YES
EXCLUDE                = bindings/cpp/include/openpit/detail \
                         bindings/cpp/include/openpit/asyncengine/strategy.hpp
EXCLUDE_PATTERNS       = */.cache/* */build/*
EXCLUDE_SYMBOLS        = openpit::detail \
                         openpit::detail::* \
                         openpit::accountadjustment::detail \
                         openpit::accountadjustment::detail::* \
                         openpit::accounts::detail \
                         openpit::accounts::detail::* \
                         openpit::asyncengine::detail \
                         openpit::asyncengine::detail::* \
                         openpit::marketdata::detail \
                         openpit::marketdata::detail::* \
                         openpit::model::detail \
                         openpit::model::detail::* \
                         openpit::pretrade::detail \
                         openpit::pretrade::detail::* \
                         openpit::pretrade::policies::detail \
                         openpit::pretrade::policies::detail::*

FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = bindings/cpp/include
MARKDOWN_SUPPORT       = YES
TOC_INCLUDE_HEADINGS   = 4
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES
MULTILINE_CPP_IS_BRIEF = NO
TYPEDEF_HIDES_STRUCT   = NO
BUILTIN_STL_SUPPORT    = YES
CPP_CLI_SUPPORT        = NO
OPTIMIZE_OUTPUT_FOR_C  = NO
OPTIMIZE_OUTPUT_JAVA   = NO
OPTIMIZE_FOR_FORTRAN   = NO
OPTIMIZE_OUTPUT_VHDL   = NO
OPTIMIZE_OUTPUT_SLICE  = NO

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_PRIV_VIRTUAL   = NO
EXTRACT_PACKAGE        = NO
EXTRACT_STATIC         = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
HIDE_FRIEND_COMPOUNDS  = YES
INTERNAL_DOCS          = NO
CASE_SENSE_NAMES       = YES
HIDE_SCOPE_NAMES       = NO
SHOW_INCLUDE_FILES     = NO
SHOW_USED_FILES        = NO
SHOW_FILES             = YES
SHOW_NAMESPACES        = YES
INLINE_INFO            = YES
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES
SOURCE_BROWSER         = NO
VERBATIM_HEADERS       = NO
REFERENCES_LINK_SOURCE = NO

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO
WARN_AS_ERROR          = YES
WARN_FORMAT            = "$file:$line: $text"

GENERATE_HTML          = YES
HTML_OUTPUT            = .
HTML_DYNAMIC_SECTIONS  = NO
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
SEARCHENGINE           = YES
SERVER_BASED_SEARCH    = NO
GENERATE_LATEX         = NO
GENERATE_XML           = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO

GENERATE_TODOLIST      = NO
GENERATE_TESTLIST      = NO
GENERATE_BUGLIST       = YES
GENERATE_DEPRECATEDLIST = YES
